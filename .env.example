# Alert rules live in rules.json (see README "Alert rules"). TARGET_DATES/TARGET_ROUTES
# below are only a fallback used when rules.json is empty/absent: they generate one
# "increase" rule per date x route. To override rules.json without a code change (e.g. on
# Railway), set ALERT_RULES to a JSON array of rule objects.
TARGET_DATES=2026-08-19,2026-08-20
TARGET_ROUTES=2A,2B,3A
# ALERT_RULES=[{"type":"below_threshold","date":"2026-08-19","route":"1C","slot":"08:00","threshold":20}]
PREFERRED_NOTIFICATION=telegram
BACKUP_NOTIFICATIONS=

POLL_INTERVAL_SECONDS=1800
JITTER_SECONDS=300
SQLITE_PATH=data/availability.sqlite3
LOG_LEVEL=INFO
PROVIDER_MODE=auto
RUN_MONITOR_IN_WEB=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Optional Slack webhook
SLACK_WEBHOOK_URL=

# Official public endpoints. Override only if the official site changes.
OFFICIAL_SITE_BASE_URL=https://tuboleto.cultura.pe
OFFICIAL_API_BASE_URL=https://api-tuboleto.cultura.pe
OFFICIAL_PLACE_SLUG=llaqta_machupicchu
OFFICIAL_PLACE_ID=1
OFFICIAL_POINT_OF_SALE=5

# These values are shipped in the public official frontend bundle and may rotate.
OFFICIAL_API_SECRET=5t4jPtv4LpmGgWU7ZYk8FhZf5LNTpk
